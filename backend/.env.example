PORT=3000
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTL (ms)
CACHE_SEARCH_TTL_MS=900000
CACHE_DETAIL_TTL_MS=1800000

# Encar request queue
ENCAR_QUEUE_CONCURRENCY=8
ENCAR_REQUEST_DELAY_MS=300
BROWSER_POOL_SIZE=3

# Currency
KRW_TO_USD_RATE=1350

# PostgreSQL (Supabase)
# Замените на вашу строку подключения из Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Webhook (36789.ru)
ENCAR_WEBHOOK_TOKEN=1521fc3c105961e2d07ff690a2fa3b28
ENCAR_USER_ID=0bfa237dc942790a2b09

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173
